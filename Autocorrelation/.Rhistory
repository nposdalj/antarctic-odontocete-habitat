autocorrelation <- function(site_presence) {
for (x in species_list) {
BlockMod <- gam(species_list[x] ~ bs(Julian.Day, k=4), data = site_presence, family = binomial)
ACF = acf(residuals(BlockMod),lag.max = 100)
CI = ggfortify:::confint.acf(ACF)
ACFidx = which(ACF[["acf"]] < CI, arr.ind=TRUE)
if (site == 'NFC'){
ACFval = 81
} else
if (site == 'HAT_B'){
ACFval = 100
} else {
ACFval = ACFidx[1] }
}
}
autocorrelation(EI_presence)
library(car)
install.packages("car")
library(car)
autocorrelation <- function(site_presence) {
for (x in species_list) {
BlockMod <- glm(species_list[x] ~ bs(Julian.Day, k=4), data = site_presence, family = binomial)
ACF = acf(residuals(BlockMod),lag.max = 100)
CI = ggfortify:::confint.acf(ACF)
ACFidx = which(ACF[["acf"]] < CI, arr.ind=TRUE)
if (site == 'NFC'){
ACFval = 81
} else
if (site == 'HAT_B'){
ACFval = 100
} else {
ACFval = ACFidx[1] }
}
}
autocorrelation(EI_presence)
